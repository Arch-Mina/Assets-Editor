<Window x:Class="Assets_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assets_Editor"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Assets Editor"
        Height="700"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        WindowStyle="None"
        ResizeMode="CanResize"
        FlowDirection="LeftToRight"
        Background="{StaticResource AppWindowBackgroundBrush}"
        Style="{StaticResource MaterialDesignWindow}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SelectableTextBlockStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CaretBrush" Value="{x:Null}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="CompactTextButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
        <Style x:Key="MainInfoCard" TargetType="Border" BasedOn="{StaticResource EditorToolbarBorder}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        </Style>
        <Style x:Key="AssetsPathBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AppRoundedInputTextBox}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                    <Setter Property="TextElement.Foreground" Value="{StaticResource AppTextBrush}"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ToggleRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="MainTitleButton" TargetType="Button" BasedOn="{StaticResource TopBarIconButton}" />
        <local:BooleanInverter x:Key="BooleanInverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{StaticResource AppWindowBackgroundBrush}"
          IsHitTestVisible="{Binding ElementName=PresetDialogHost, Path=IsOpen, Mode=OneWay, Converter={StaticResource BooleanInverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#141F34" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0" FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Image Source="pack://application:,,,/Resources/Walking_000.png"
                           Width="22"
                           Height="22"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Margin="0,0,8,0" />
                    <TextBlock Text="Assets Editor" Foreground="{StaticResource AppTextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True" HorizontalAlignment="Right" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource MainTitleButton}"
                            Click="TitleMinimize_Click"
                            ToolTip="Minimize">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16" />
                    </Button>
                    <Button Style="{StaticResource MainTitleButton}"
                            Click="TitleMaximize_Click"
                            ToolTip="Maximize">
                        <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16" />
                    </Button>
                    <Button Style="{StaticResource MainTitleButton}"
                            Click="TitleClose_Click"
                            ToolTip="Close">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <materialDesign:DialogHost x:Name="PresetDialogHost"
                                   Grid.Row="1"
                                   Placement="Center"
                                   OverlayBackground="#99000000">
            <materialDesign:DialogHost.DialogContent>
                <Border Style="{StaticResource EditorPanelBorder}" Padding="22" MinWidth="360">
                    <StackPanel>
                        <TextBlock x:Name="PresetDialogTitle"
                                   Text="(action)"
                                   Style="{StaticResource EditorSectionTitle}" />
                        <TextBox x:Name="PresetNameTextBox"
                                 Height="36"
                                 materialDesign:HintAssist.Hint="Preset name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button x:Name="PresetDialogCancelBtn"
                                    Width="108"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Click="ModifyPresetCancel_Click"
                                    ToolTip="Cancel preset edit">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Close" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cancel"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="PresetDialogOKBtn"
                                    Width="108"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Margin="10,0,0,0"
                                    Click="ModifyPresetConfirm_Click"
                                    ToolTip="Confirm preset edit">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Check" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="OK"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </materialDesign:DialogHost.DialogContent>
            <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

                <Border x:Name="PresetsConfGrid"
                    Grid.Row="0"
                    Style="{StaticResource EditorPanelBorder}"
                    Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="TuneVariant" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Editor Settings" Style="{StaticResource EditorSectionTitle}" Margin="0,0,18,0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CurrentPresetDropdown"
                                  ItemsSource="{Binding Presets}"
                                  Width="200"
                                  Height="34"
                                  SelectedIndex="0"
                                  IsReadOnly="True"
                                  materialDesign:HintAssist.Hint="Preset"
                                  Style="{StaticResource AppComboBoxStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="NewPresetBtn"
                                Style="{StaticResource CompactTextButton}"
                                Click="NewPreset_Click"
                                ToolTip="Create a new preset">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="New"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="RenamePresetBtn"
                                Style="{StaticResource CompactTextButton}"
                                Click="RenamePreset_Click"
                                ToolTip="Rename current preset">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Rename" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Rename"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="DeletePresetBtn"
                                Style="{StaticResource CompactTextButton}"
                                Click="DeletePreset_Click"
                                ToolTip="Remove preset">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DeleteOutline" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Delete"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"/>
                </Grid>
            </Border>

                <Border x:Name="AssetsConfGrid"
                    Grid.Row="1"
                    Style="{StaticResource EditorPanelBorder}"
                    Margin="0,14,0,0"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="FolderCogOutline" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Assets Settings" Style="{StaticResource EditorSectionTitle}" Margin="0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="DAT File Path:" VerticalAlignment="Center" Padding="0,0,12,0"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="AssetsPath"
                                     VerticalAlignment="Center"
                                     Height="34"
                                     IsReadOnly="True"
                                     materialDesign:HintAssist.Hint="Select assets folder..."
                                     Style="{StaticResource AssetsPathBoxStyle}" />
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Opacity="0"
                                    Cursor="Hand"
                                    Click="SelectAssetsFolder" />
                        </Grid>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    materialDesign:RippleAssist.IsDisabled="True"
                                    Width="34"
                                    Height="34"
                                    Click="SelectAssetsFolder"
                                    ToolTip="Select path">
                                <materialDesign:PackIcon Kind="FolderSearchOutline" Width="22" Height="22"/>
                            </Button>
                            <Button ToolTip="Copy Path"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Width="34"
                                    Height="34"
                                    Click="CopyAssetsPath"
                                    Margin="2,0,0,0">
                                <materialDesign:PackIcon Kind="ContentCopy" Height="20" Width="20" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon x:Name="AssetsPathBaseIcon"
                                                     Kind="InfoOutline"
                                                     Width="16"
                                                     Height="16"
                                                     Visibility="Hidden"
                                                     VerticalAlignment="Center"/>

                            <materialDesign:PackIcon x:Name="AssetsPathLoadingIcon"
                                                     Kind="Loading"
                                                     Width="16"
                                                     Height="16"
                                                     Visibility="Visible"
                                                     VerticalAlignment="Center">
                                <materialDesign:PackIcon.RenderTransform>
                                    <RotateTransform x:Name="LoadingRotate"
                                                     Angle="0"
                                                     CenterX="8"
                                                     CenterY="8"/>
                                </materialDesign:PackIcon.RenderTransform>
                                <materialDesign:PackIcon.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="LoadingRotate"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0"
                                                                 To="360"
                                                                 Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </materialDesign:PackIcon.Triggers>
                            </materialDesign:PackIcon>

                            <TextBlock x:Name="AssetsPathLoadingMessage"
                                       Text="Initializing ..."
                                       Padding="6,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource AppMutedTextBrush}"/>
                        </StackPanel>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="1.25*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource MainInfoCard}">
                                <TextBox x:Name="AppearancesCount"
                                         Style="{StaticResource SelectableTextBlockStyle}"
                                         Text="Items:&#9;&#9;0&#10;Outfits:&#9;&#9;0&#10;Effects:&#9;&#9;0&#10;Missiles:&#9;&#9;0"/>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource MainInfoCard}" Margin="12,0">
                                <StackPanel>
                                    <StackPanel Style="{StaticResource ToggleRow}">
                                        <ToggleButton x:Name="DatExtendedToggle" Checked="DatExtended_Changed" Unchecked="DatExtended_Changed" IsEnabled="False"/>
                                        <Label Content="Extended" Padding="8,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource ToggleRow}">
                                        <ToggleButton x:Name="DatTransparentToggle" Checked="DatTransparent_Changed" Unchecked="DatTransparent_Changed" IsEnabled="False"/>
                                        <Label Content="Transparency" Padding="8,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource ToggleRow}">
                                        <ToggleButton x:Name="DatAnimationsToggle" Checked="DatAnimations_Changed" Unchecked="DatAnimations_Changed" IsEnabled="False"/>
                                        <Label Content="Improved Animations" Padding="8,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource ToggleRow}" Margin="0">
                                        <ToggleButton x:Name="DatFrameGroupsToggle" Checked="DatFrameGroup_Changed" Unchecked="DatFrameGroup_Changed" IsEnabled="False"/>
                                        <Label Content="Frame Groups" Padding="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource MainInfoCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox x:Name="AssetsVersionInfo"
                                             Style="{StaticResource SelectableTextBlockStyle}"
                                             Text="No version loaded" />
                                    <ComboBox x:Name="DatStructureDropdown"
                                              Grid.Row="1"
                                              Height="30"
                                              SelectedIndex="1"
                                              IsReadOnly="True"
                                              IsEnabled="False"
                                              SelectionChanged="DatStructureType_SelectionChanged"
                                              Style="{StaticResource AppComboBoxStyle}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <materialDesign:Snackbar x:Name="StatusBar"
                                                 MessageQueue="{materialDesign:MessageQueue}"
                                                 IsActive="False"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                 Padding="0,-20,0,0" />

                        <Button x:Name="LoadAssets"
                                HorizontalAlignment="Center"
                                IsEnabled="False"
                                Click="LoadAssets_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="24,6">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Load Assets" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ProgressBar x:Name="LoadProgress"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Width="220"
                                             HorizontalAlignment="Center"
                                             Margin="0,5,0,0" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </materialDesign:DialogHost>
    </Grid>
</Window>

