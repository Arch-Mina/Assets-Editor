<Window x:Class="Assets_Editor.SprEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assets_Editor"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Sprite Manager"
        Height="640"
        Width="740"
        MinHeight="560"
        MinWidth="700"
        Background="{StaticResource AppWindowBackgroundBrush}"
        Style="{StaticResource MaterialDesignWindow}">
    <Window.CommandBindings>
        <CommandBinding Command="Paste" Executed="OnPaste"/>
        <CommandBinding Command="Delete" Executed="OnDelete"/>
    </Window.CommandBindings>
    <Window.Resources>
        <local:ArithmeticConverter x:Key="ArithmeticConverter" />
        <local:NullableColorToBrushConverter x:Key="NullableColorToBrushConverter" />
        <local:BooleanInverter x:Key="BooleanInverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid x:Name="MainContent"
          Margin="8"
          IsHitTestVisible="{Binding ElementName=NewSheetDialogHost, Path=IsOpen, Mode=OneWay, Converter={StaticResource BooleanInverter}}">
        <materialDesign:DialogHost x:Name="NewSheetDialogHost" OverlayBackground="#99000000">
            <materialDesign:DialogHost.DialogContent>
                <Border Style="{StaticResource ToolPanelBorder}" Width="320" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="ImagePlus" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock Text="New Sheet" Style="{StaticResource ToolPanelTitle}"/>
                        </StackPanel>
                        <ComboBox x:Name="TSpriteType" SelectedIndex="0" Margin="0,0,0,14"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Click="CreateNewSheet_Click" Style="{StaticResource ToolPrimaryButton}" Content="Create"/>
                            <Button Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{StaticResource ToolActionButton}" Content="Cancel"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </materialDesign:DialogHost.DialogContent>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="420"/>
                    <ColumnDefinition Width="270"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ToolPanelBorder}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource ToolPanelHeader}">
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <materialDesign:PackIcon Kind="ImageFrame" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Current Sheet" Style="{StaticResource ToolPanelTitle}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                    <Button x:Name="ImportSheet"
                                            Style="{StaticResource ToolIconButton}"
                                            ToolTip="Save to assets"
                                            PreviewMouseLeftButtonDown="ImportSheet_PreviewMouseLeftButtonDown">
                                        <materialDesign:PackIcon Kind="PackageDown" Width="20" Height="20"/>
                                    </Button>
                                    <Button x:Name="ExportSheet"
                                            Style="{StaticResource ToolIconButton}"
                                            ToolTip="Export Sheet"
                                            PreviewMouseLeftButtonDown="ExportSheet_PreviewMouseLeftButtonDown">
                                        <materialDesign:PackIcon Kind="ContentSaveMove" Width="20" Height="20"/>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="10"
                                Background="{StaticResource AppSurfaceRaisedBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                ClipToBounds="True">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <WrapPanel x:Name="SheetWrap"
                                           ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                           Background="{StaticResource AppSurfaceRaisedBrush}"
                                           Width="400"
                                           Height="400"/>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource ToolPanelHeader}" Margin="0,0,0,2">
                            <TextBlock Text="Use paste/delete commands or toolbar actions for sheet editing."
                                       Foreground="{StaticResource AppMutedTextBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <materialDesign:Snackbar Grid.Row="3"
                                                 x:Name="SprStatusBar"
                                                 MessageQueue="{materialDesign:MessageQueue}"
                                                 IsActive="False"
                                                 HorizontalAlignment="Stretch"
                                                 Height="34"
                                                 HorizontalContentAlignment="Left"
                                                 VerticalContentAlignment="Center"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                 Padding="12,0"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ToolPanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource ToolPanelHeader}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ImageMultiple" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Sprite Sheets" Style="{StaticResource ToolPanelTitle}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource AppSurfaceRaisedBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <xctk:IntegerUpDown x:Name="A_SearchSprId" Minimum="1" Margin="0,0,6,0"/>
                                <Button x:Name="SearchSpr"
                                        Grid.Column="1"
                                        Style="{StaticResource ToolIconButton}"
                                        ToolTip="Search Sprite Sheet"
                                        Click="SearchSpr_Click">
                                    <materialDesign:PackIcon Kind="ImageSearch" Width="20" Height="20"/>
                                </Button>
                            </Grid>
                        </Border>

                        <ListView x:Name="SheetsList"
                                  Grid.Row="2"
                                  Margin="8"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.CacheLength="2"
                                  VirtualizingPanel.CacheLengthUnit="Item"
                                  SelectionMode="Extended"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ItemContainerStyle="{StaticResource ToolListTileItem}">
                            <xctk:MagnifierManager.Magnifier>
                                <xctk:Magnifier Background="White"
                                                Radius="80"
                                                ZoomFactor="0.3"
                                                FrameType="Circle"
                                                BorderBrush="{StaticResource AppAccentBrush}"
                                                BorderThickness="2"
                                                Width="160"
                                                Height="160"
                                                IsUsingZoomOnMouseWheel="True"
                                                ZoomFactorOnMouseWheel="0.5"/>
                            </xctk:MagnifierManager.Magnifier>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Height="110" Padding="8" Background="{StaticResource AppSurfaceRaisedBrush}" CornerRadius="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding Id}"
                                                       Foreground="{StaticResource AppTextBrush}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,6"/>
                                            <Border Grid.Row="1"
                                                    Background="{StaticResource AppSurfaceBrush}"
                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="5"
                                                    Padding="4">
                                                <Image Source="{Binding Image}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Border Grid.Row="3" Style="{StaticResource ToolPanelHeader}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="CreateSheet"
                                        Style="{StaticResource ToolIconButton}"
                                        ToolTip="Create New Sheet"
                                        Click="CreateSheet_Click">
                                    <materialDesign:PackIcon Kind="ImagePlus" Width="20" Height="20"/>
                                </Button>
                                <Button x:Name="EditSheet"
                                        Style="{StaticResource ToolIconButton}"
                                        ToolTip="Edit Sheet"
                                        PreviewMouseLeftButtonDown="EditSheet_PreviewMouseLeftButtonDown">
                                    <materialDesign:PackIcon Kind="ImageEdit" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </materialDesign:DialogHost>
    </Grid>
</Window>
