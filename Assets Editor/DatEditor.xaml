<Window x:Class="Assets_Editor.DatEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assets_Editor" xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" 
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="DatEditor" Height="880" Width="1220" MinHeight="720" MinWidth="1120"
        WindowStyle="None" ResizeMode="CanResize"
        FlowDirection="LeftToRight"
        materialDesign:ShadowAssist.CacheMode="{x:Null}" Loaded="Window_Loaded"
        Background="{StaticResource AppWindowBackgroundBrush}"
        Style="{StaticResource MaterialDesignWindow}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <local:ArithmeticConverter x:Key="ArithmeticConverter" />
        <local:NullableColorToBrushConverter x:Key="NullableColorToBrushConverter" />
        <local:BooleanInverter x:Key="BooleanInverter"/>
        <local:BooleanOrInverterConverter x:Key="BooleanOrInverterConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="DatPanelBorder" TargetType="Border" BasedOn="{StaticResource EditorPanelBorder}">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>
        <Style x:Key="DatPanelHeader" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
        <Style x:Key="DatIconButton" TargetType="Button" BasedOn="{StaticResource TopBarIconButton}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Padding" Value="3" />
        </Style>
        <Style x:Key="DatActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
        </Style>
        <Style x:Key="DatActionPrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#05171C" />
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
        </Style>
        <Style x:Key="DatTopCommandButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        </Style>
        <Style x:Key="DatTopCommandAccentButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="#072126" />
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
        </Style>
        <Style x:Key="DatListViewItem" TargetType="ListViewItem" BasedOn="{StaticResource MaterialDesignGridViewItem}">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="DatAssetTileItem" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="TileRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileRoot" Property="Background" Value="{StaticResource AppSurfaceHoverBrush}" />
                                <Setter TargetName="TileRoot" Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TileRoot" Property="Background" Value="#3A2356" />
                                <Setter TargetName="TileRoot" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DatFieldGroup" TargetType="GroupBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Style="{StaticResource DatPanelBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource DatPanelHeader}">
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      TextElement.FontWeight="SemiBold"
                                                      TextElement.FontSize="14"/>
                                </Border>
                                <ContentPresenter Grid.Row="1" Margin="0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DatPropertyCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="DatPropertySectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,12,0,8" />
        </Style>
        <Style x:Key="DatPropertyCardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="DatFormLabel" TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="DatFormCheckBox" TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DatFormTextBox" TargetType="TextBox" BasedOn="{StaticResource AppRoundedInputTextBox}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="7,2" />
        </Style>
        <Style x:Key="DatFormUpDown" TargetType="xctk:IntegerUpDown" BasedOn="{StaticResource {x:Type xctk:IntegerUpDown}}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ShowButtonSpinner" Value="False" />
        </Style>
        <Style x:Key="TextureCard" TargetType="Border" BasedOn="{StaticResource DatPropertyCard}">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="TextureCardTitle" TargetType="TextBlock" BasedOn="{StaticResource DatPropertyCardTitle}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="TextureInlineLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="TextureDirectionButton" TargetType="Button" BasedOn="{StaticResource DatIconButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="TexturePreviewButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#05171C" />
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </Window.Resources>
    <Grid x:Name="MainContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource AppWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.IsHitTestVisible>
            <MultiBinding Converter="{StaticResource BooleanOrInverterConverter}">
                <!-- If either dialog is open, background must NOT be clickable -->
                <Binding ElementName="ComppileDialogHost" Path="IsOpen"/>
                <Binding ElementName="CompileToImagesDialogHost" Path="IsOpen"/>
            </MultiBinding>
        </Grid.IsHitTestVisible>
        <Border Grid.Row="0" Background="#141F34" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0" FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Image Source="pack://application:,,,/Resources/Walking_000.png"
                           Width="22"
                           Height="22"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Margin="0,0,8,0"/>
                    <TextBlock Text="DatEditor" Foreground="{StaticResource AppTextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,18,0"/>
                    <Border Width="1" Height="18" Background="{StaticResource AppBorderBrush}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource DatTopCommandAccentButton}" Click="Compile_Click" ToolTip="Compile assets">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlayCircleOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                <TextBlock Text="Compile" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DatTopCommandButton}" Click="ImportItems_Click" ToolTip="Import AEC/OBD">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseImportOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                <TextBlock Text="Import" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DatTopCommandButton}" Click="CompileLegacy_Click" ToolTip="Export to legacy">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExportOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                <TextBlock Text="Legacy" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DatTopCommandButton}" Click="CompileToImages_Click" ToolTip="Export as images">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ImageMultipleOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                <TextBlock Text="Images" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DatTopCommandButton}" Click="SearchItem_Click" ToolTip="Search item">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Width="15" Height="15" Margin="0,0,6,0" />
                                <TextBlock Text="Search" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DatTopCommandButton}" Click="ShowLogger" ToolTip="Show logger">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TextBoxSearchOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                <TextBlock Text="Logs" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DatTopCommandButton}" Click="OpenLuaWindow_Click" ToolTip="Lua script editor">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CodeBraces" Width="15" Height="15" Margin="0,0,6,0" />
                                <TextBlock Text="Lua" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DatTopCommandButton}" Click="About_Click" ToolTip="About">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="15" Height="15" />
                        </Button>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True" HorizontalAlignment="Right" FlowDirection="LeftToRight">
                    <Border Width="1" Height="18" Background="{StaticResource AppBorderBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <Button Style="{StaticResource DatIconButton}"
                            Click="TitleMinimize_Click"
                            ToolTip="Minimize">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource DatIconButton}"
                            Click="TitleMaximize_Click"
                            ToolTip="Maximize">
                        <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource DatIconButton}"
                            Click="TitleClose_Click"
                            ToolTip="Close">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <materialDesign:DialogHost Grid.Row="1" x:Name="ComppileDialogHost" OverlayBackground="#99000000" Background="Transparent">
            <materialDesign:DialogHost.DialogContent>
                <GroupBox x:Name="CompileBox" Header="Export To Legacy" Width="350">
                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        <CheckBox Grid.Row="0" x:Name="C_Transparent" Content="Transparent" Margin="5,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="210"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Converting Objects"/>
                            <ProgressBar Grid.Column="1" x:Name="LoadProgress1" Minimum="0" Maximum="100" Value="0" Width="200" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5,0,5,10" Height="8" />
                        </Grid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="210"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Converting Sprites"/>
                            <ProgressBar Grid.Column="1" x:Name="LoadProgress2" Minimum="0" Maximum="100" Value="0" Width="200" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5,0,5,10" Height="8" />
                        </Grid>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Click="CompileLegacy" Content="Export" Width="100" Margin="0,0,20,0"/>
                            <Button Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Content="Cancel" Width="100"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>

        <materialDesign:DialogHost Grid.Row="1" x:Name="CompileToImagesDialogHost" OverlayBackground="#99000000" Background="Transparent" >
            <materialDesign:DialogHost.DialogContent>
                <GroupBox x:Name="CompileToImagesBox" Header="Export As Images" Width="500">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="160"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <Label Content="Converting Objects"/>
                            <ProgressBar x:Name="ImgExportProgress" Minimum="0" Maximum="100" Value="0" Width="210" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,0,0,10" Height="8" />
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Grid.Row="1" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="5,5">
                                <CheckBox x:Name="ExportItemsCheckBox" Content="Items" Margin="5,0"/>
                                <TextBlock x:Name="ExportItemsProgressText" Text="0/0" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Label Content="Min ID:" VerticalAlignment="Center" Margin="5,0"/>
                                    <xctk:IntegerUpDown x:Name="ExportItemsMinId" Width="80" Minimum="100" Margin="5,0"/>
                                    <Label Content="Max ID:" VerticalAlignment="Center" Margin="5,0"/>
                                    <xctk:IntegerUpDown x:Name="ExportItemsMaxId" Width="80" Minimum="100" Margin="5,0"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,5">
                                <CheckBox x:Name="ExportOutfitsCheckBox" Content="Outfits" Margin="5,0"/>
                                <TextBlock x:Name="ExportOutfitsProgressText" Text="0/0" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Label Content="Min ID:" VerticalAlignment="Center" Margin="5,0"/>
                                    <xctk:IntegerUpDown x:Name="ExportOutfitsMinId" Width="80" Minimum="1" Margin="5,0"/>
                                    <Label Content="Max ID:" VerticalAlignment="Center" Margin="5,0"/>
                                    <xctk:IntegerUpDown x:Name="ExportOutfitsMaxId" Width="80" Minimum="1" Margin="5,0"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,5">
                                <CheckBox x:Name="ExportEffectsCheckBox" Content="Effects" Margin="5,0"/>
                                <TextBlock x:Name="ExportEffectsProgressText" Text="0/0" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Label Content="Min ID:" VerticalAlignment="Center" Margin="5,0"/>
                                    <xctk:IntegerUpDown x:Name="ExportEffectsMinId" Width="80" Minimum="1" Margin="5,0"/>
                                    <Label Content="Max ID:" VerticalAlignment="Center" Margin="5,0"/>
                                    <xctk:IntegerUpDown x:Name="ExportEffectsMaxId" Width="80" Minimum="1" Margin="5,0"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,5">
                                <CheckBox x:Name="ExportMissilesCheckBox" Content="Missiles" Margin="5,0"/>
                                <TextBlock x:Name="ExportMissilesProgressText" Text="0/0" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Label Content="Min ID:" VerticalAlignment="Center" Margin="5,0"/>
                                    <xctk:IntegerUpDown x:Name="ExportMissilesMinId" Width="80" Minimum="1" Margin="5,0"/>
                                    <Label Content="Max ID:" VerticalAlignment="Center" Margin="5,0"/>
                                    <xctk:IntegerUpDown x:Name="ExportMissilesMaxId" Width="80" Minimum="1" Margin="5,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center">
                            <Label Content="Export Directory:" VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox x:Name="ExportImageDirectoryTextBox" Width="200" Margin="5,0"/>
                            <Button Content="Browse" Click="ExportAsImageDirectoryPicker_Click" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Click="CompileAsImages" Content="Export" Width="100" Margin="0,0,20,0"/>
                            <Button Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Content="Cancel" Width="100"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="236"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DatPanelBorder}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="62"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource DatPanelHeader}" Padding="10,8">
                        <ComboBox x:Name="ObjectMenu" Style="{StaticResource AppComboBoxStyle}" HorizontalAlignment="Stretch" VerticalAlignment="Center" FontWeight="SemiBold" SelectionChanged="ObjectMenuChanged" SelectedIndex="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Focusable="False" SnapsToDevicePixels="True" FlowDirection="LeftToRight" Height="40">
                            <ComboBoxItem Content="Outfits"/>
                            <ComboBoxItem Content="Items"/>
                            <ComboBoxItem Content="Effects"/>
                            <ComboBoxItem Content="Missiles"/>
                        </ComboBox>
                    </Border>
                    <ListView Grid.Row="1" x:Name="ObjListView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.CacheLength="2" VirtualizingPanel.CacheLengthUnit="Item" ScrollViewer.CanContentScroll="True" VirtualizingPanel.ScrollUnit="Item" SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.ScrollChanged="ObjListView_ScrollChanged" SelectionChanged="ObjListView_SelectionChanged" SelectedIndex="0" Margin="0" ItemContainerStyle="{StaticResource DatAssetTileItem}">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Height="58" Padding="8,6" CornerRadius="6" Background="{StaticResource AppSurfaceRaisedBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image Source="{Binding Image}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" MaxWidth="38" MaxHeight="38" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Id}" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontWeight="SemiBold" FontSize="13"/>
                                        <Ellipse Grid.Column="2" Width="8" Height="8" Fill="{StaticResource AppAccentBrush}" VerticalAlignment="Center" ToolTip="Export List" Visibility="{Binding Exported, Converter={StaticResource BoolToVis}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <xctk:IntegerUpDown Grid.Row="2" x:Name="ObjListViewSelectedIndex" ParsingNumberStyle="Integer" ValueChanged="ObjListViewSelectedIndex_ValueChanged" Minimum="0" Focusable="False" Margin="0,4,0,0" Background="{StaticResource AppSurfaceRaisedBrush}"/>
                    <Border Grid.Row="3" Style="{StaticResource DatPanelHeader}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="0,4,0,0" Padding="10,8">
