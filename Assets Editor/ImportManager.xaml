<Window x:Class="Assets_Editor.ImportManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assets_Editor"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Import Manager"
        Height="860"
        Width="880"
        MinHeight="720"
        MinWidth="820"
        Background="{StaticResource AppWindowBackgroundBrush}"
        materialDesign:ShadowAssist.CacheMode="{x:Null}"
        Style="{StaticResource MaterialDesignWindow}">
    <Window.Resources>
        <DataTemplate x:Key="ImportListTemplate">
            <Border Height="52" Padding="7,4" Background="{StaticResource AppSurfaceRaisedBrush}" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Source="{Binding Image}"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           MaxWidth="32"
                           MaxHeight="32"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Id}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AppTextBrush}"
                               FontWeight="SemiBold"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="8">
        <materialDesign:DialogHost x:Name="ImportAsDialogHost" OverlayBackground="#99000000">
            <materialDesign:DialogHost.DialogContent>
                <Border Style="{StaticResource ToolPanelBorder}" Width="320" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="PuzzleEdit" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock Text="Import Object As" Style="{StaticResource ToolPanelTitle}"/>
                        </StackPanel>
                        <ComboBox SelectedIndex="0" Margin="0,0,0,14">
                            <ComboBoxItem Content="Outfit"/>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Click="ConvertObject" Content="Import" Style="{StaticResource ToolPrimaryButton}"/>
                            <Button Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Content="Cancel" Style="{StaticResource ToolActionButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </materialDesign:DialogHost.DialogContent>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ToolPanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource ToolPanelHeader}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseImportOutline" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Import From Client" Style="{StaticResource ToolPanelTitle}"/>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1" Margin="10,8,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Client Path:" VerticalAlignment="Center" Padding="0" Margin="0,0,8,0"/>
                            <TextBox x:Name="ClientPathText" Grid.Column="1" IsEnabled="False" Margin="0,0,8,0"/>
                            <CheckBox Grid.Column="2" x:Name="SprTransparent" Content="Transparent" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button x:Name="OpenClient"
                                    Grid.Column="3"
                                    Style="{StaticResource ToolIconButton}"
                                    Click="OpenClient_Click"
                                    ToolTip="Open client directory">
                                <materialDesign:PackIcon Kind="CardSearch" Height="20" Width="20"/>
                            </Button>
                            <ProgressBar x:Name="LoadProgress"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="4"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0"
                                         Margin="0,42,0,0"
                                         Height="6"/>
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="235"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource ToolPanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource ToolPanelHeader}">
                                <ComboBox x:Name="ObjectMenu"
                                          SelectionChanged="ObjectMenuChanged"
                                          SelectedIndex="0"
                                          HorizontalContentAlignment="Center"
                                          FontWeight="SemiBold">
                                    <ComboBoxItem Content="Outfits"/>
                                    <ComboBoxItem Content="Items"/>
                                    <ComboBoxItem Content="Effects"/>
                                    <ComboBoxItem Content="Missiles"/>
                                </ComboBox>
                            </Border>
                            <ListView Grid.Row="1"
                                      x:Name="ObjListView"
                                      Margin="8"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.CacheLength="2"
                                      VirtualizingPanel.CacheLengthUnit="Item"
                                      SelectionMode="Extended"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.ScrollChanged="ObjListView_ScrollChanged"
                                      SelectionChanged="ObjListView_SelectionChanged"
                                      MouseMove="ObjListView_Drag"
                                      SelectedIndex="0"
                                      ItemTemplate="{StaticResource ImportListTemplate}"
                                      ItemContainerStyle="{StaticResource ToolListTileItem}"/>
                            <xctk:IntegerUpDown Grid.Row="2"
                                                x:Name="ObjListViewSelectedIndex"
                                                ParsingNumberStyle="Integer"
                                                ValueChanged="ObjListViewSelectedIndex_ValueChanged"
                                                Minimum="0"
                                                Focusable="False"
                                                Margin="8,0,8,6"/>
                            <Border Grid.Row="3" Style="{StaticResource ToolPanelHeader}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="ObjectImport"
                                            Style="{StaticResource ToolIconButton}"
                                            ToolTip="Import Object"
                                            PreviewMouseLeftButtonDown="ObjectImport_PreviewMouseLeftButtonDown">
                                        <materialDesign:PackIcon Kind="ArrowDownBox" Width="20" Height="20"/>
                                    </Button>
                                    <Button x:Name="ObjectImportAs"
                                            Style="{StaticResource ToolIconButton}"
                                            ToolTip="Import Object As"
                                            PreviewMouseLeftButtonDown="ObjectImportAs_PreviewMouseLeftButtonDown">
                                        <materialDesign:PackIcon Kind="PuzzleEdit" Width="20" Height="20"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"/>

                    <Border Grid.Column="2" Style="{StaticResource ToolPanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource ToolPanelHeader}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ImageArea" Height="22" Width="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sprite List" Style="{StaticResource ToolPanelTitle}"/>
                                </StackPanel>
                            </Border>
                            <ListView Grid.Row="1"
                                      x:Name="SprListView"
                                      Margin="8"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.CacheLength="2"
                                      VirtualizingPanel.CacheLengthUnit="Item"
                                      SelectionMode="Extended"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.ScrollChanged="SprListView_ScrollChanged"
                                      SelectedIndex="0"
                                      ItemTemplate="{StaticResource ImportListTemplate}"
                                      ItemContainerStyle="{StaticResource ToolListTileItem}"/>
                            <xctk:IntegerUpDown Grid.Row="2"
                                                x:Name="SprListViewSelectedIndex"
                                                ParsingNumberStyle="Integer"
                                                Value="{Binding ElementName=SprListView, Path=SelectedIndex, Mode=TwoWay}"
                                                ValueChanged="SprListViewSelectedIndex_ValueChanged"
                                                Minimum="0"
                                                Focusable="False"
                                                Margin="8,0,8,6"/>
                            <Border Grid.Row="3" Style="{StaticResource ToolPanelHeader}">
                                <Button x:Name="ImportSpr"
                                        Style="{StaticResource ToolIconButton}"
                                        ToolTip="Import Sprite"
                                        PreviewMouseLeftButtonDown="ImportSpr_PreviewMouseLeftButtonDown"
                                        HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ArrowDownBox" Width="20" Height="20"/>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="8" HorizontalAlignment="Stretch"/>

                    <Border Grid.Column="4" Style="{StaticResource ToolPanelBorder}" VerticalAlignment="Top" MinHeight="300">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="170"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource ToolPanelHeader}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CubeScan" Height="22" Width="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Import OBD File" Style="{StaticResource ToolPanelTitle}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1"
                                    Margin="10"
                                    Background="{StaticResource AppSurfaceRaisedBrush}"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <Image x:Name="OBDImage"
                                       Stretch="None"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       MinWidth="32"
                                       MinHeight="32"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <Label Content="Select File:" VerticalAlignment="Center" Padding="0" Margin="0,0,8,0"/>
                                <Button x:Name="ImportObject"
                                        Style="{StaticResource ToolIconButton}"
                                        Content="{materialDesign:PackIcon CardSearch}"
                                        ToolTip="Select Object"
                                        PreviewMouseLeftButtonDown="ImportObject_PreviewMouseLeftButtonDown"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
                                <Label Content="View" VerticalAlignment="Center" Padding="0"/>
                                <Slider x:Name="ObjImportSlider"
                                        Width="72"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1"
                                        Minimum="0"
                                        Maximum="1"
                                        VerticalAlignment="Center"
                                        Margin="12,0"/>
                                <Label Content="Import" VerticalAlignment="Center" Padding="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </materialDesign:DialogHost>
    </Grid>
</Window>
