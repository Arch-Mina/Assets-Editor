<Window x:Class="Assets_Editor.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assets_Editor"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="About"
        Height="270"
        Width="500"
        ScrollViewer.VerticalScrollBarVisibility="Disabled"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}">
    <Border Style="{StaticResource EditorPanelBorder}" Padding="22" Margin="14">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="132" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource EditorToolbarBorder}" Width="112" Height="112" VerticalAlignment="Top" Padding="8">
                <Image Source="pack://application:,,,/Resources/Walking_000.png"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>

            <StackPanel Grid.Column="1" Margin="18,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <materialDesign:PackIcon Kind="PackageVariantClosed" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Assets Editor V2.0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Open-source tool for modifying and managing Tibia 12+ and Tibia 1098 client assets."
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                    <Run Text="Suggestions and bug reports: "/>
                    <Hyperlink NavigateUri="https://github.com/Arch-Mina/Assets-Editor" RequestNavigate="Hyperlink_OnRequestNavigate">
                        <Run Text="AssetsEditor GitHub" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                    <Run Text="Developed by "/>
                    <Hyperlink NavigateUri="https://otland.net/members/spiderot.16412/" RequestNavigate="Hyperlink_OnRequestNavigate">
                        <Run Text="SpiderOT" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock Text="{Binding ApplicationVersion}"
                           Foreground="{DynamicResource MaterialDesignHint}"
                           FontStyle="Italic"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
